# App URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=https://crm.empowerbuilding.ai

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Webhook API Key (for lead webhook authentication)
WEBHOOK_API_KEY=your-webhook-api-key

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Use localhost for dev, production domain for prod
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback
# GOOGLE_REDIRECT_URI=https://crm.empowerbuilding.ai/api/calendar/callback

# Optional: n8n webhooks for notifications
N8N_MEETING_BOOKED_WEBHOOK=
N8N_MEETING_CANCELLED_WEBHOOK=
N8N_MEETING_REMINDER_WEBHOOK=

# Facebook Conversions API (for server-side event tracking)
FACEBOOK_PIXEL_ID=your-pixel-id
FACEBOOK_CONVERSIONS_API_TOKEN=your-conversions-api-token

# Facebook System User Token (for n8n to receive leads)
# FACEBOOK_SYSTEM_USER_TOKEN=your-system-user-token
