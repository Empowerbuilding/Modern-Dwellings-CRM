# App URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=https://crm.moderndwellings.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://nmaekpidaurmuwqvgrxd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Webhook API Key (for lead webhook authentication)
WEBHOOK_API_KEY=your-webhook-api-key-here

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://crm.moderndwellings.com/api/calendar/callback

# Optional: n8n webhooks for notifications
N8N_MEETING_BOOKED_WEBHOOK=
N8N_MEETING_CANCELLED_WEBHOOK=
N8N_MEETING_REMINDER_WEBHOOK=

# Facebook Conversions API
FACEBOOK_PIXEL_ID=your-pixel-id
FACEBOOK_CONVERSIONS_API_TOKEN=your-capi-token

# Facebook OAuth (for Lead Ads integration)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=https://crm.moderndwellings.com/api/facebook/callback

# Node version for Nixpacks
NIXPACKS_NODE_VERSION=22
