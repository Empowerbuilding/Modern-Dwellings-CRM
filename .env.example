# App URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=https://crm.moderndwellings.com

# Supabase — Get from Supabase dashboard for Modern Dwellings project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Webhook API Key (for lead webhook authentication — must match CRM_WEBHOOK_API_KEY on website)
WEBHOOK_API_KEY=md_webhook_k7x9m2p4q8r1w5

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback
# GOOGLE_REDIRECT_URI=https://crm.moderndwellings.com/api/calendar/callback

# Optional: n8n webhooks for notifications
N8N_MEETING_BOOKED_WEBHOOK=
N8N_MEETING_CANCELLED_WEBHOOK=
N8N_MEETING_REMINDER_WEBHOOK=

# Facebook Conversions API (configure once Modern Dwellings pixel is set up)
FACEBOOK_PIXEL_ID=
FACEBOOK_CONVERSIONS_API_TOKEN=

# Facebook OAuth (for Lead Ads integration)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://crm.moderndwellings.com/api/facebook/callback
